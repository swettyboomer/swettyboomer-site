---
// A single store badge button. Monochrome glyphs to sit calmly on the dark
// theme. NOTE: the app stores require their *official* badge artwork for
// published listings — swap these for the official assets before submitting.
interface Props {
  store: 'microsoft' | 'apple' | 'google';
  href: string;
}
const { store, href } = Astro.props;

const meta = {
  microsoft: { small: 'Get it from', big: 'Microsoft Store' },
  apple: { small: 'Download on the', big: 'App Store' },
  google: { small: 'Get it on', big: 'Google Play' },
}[store];
---
<a
  href={href}
  class="group inline-flex items-center gap-3 rounded-lg border border-edge bg-slab px-4 py-2.5 transition-colors duration-200 hover:border-brass/50 hover:bg-slab-2"
>
  <span class="text-bone/90 transition-colors group-hover:text-brass-bright" aria-hidden="true">
    {store === 'microsoft' && (
      <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
        <rect x="2" y="2" width="9" height="9" rx="1" />
        <rect x="13" y="2" width="9" height="9" rx="1" />
        <rect x="2" y="13" width="9" height="9" rx="1" />
        <rect x="13" y="13" width="9" height="9" rx="1" />
      </svg>
    )}
    {store === 'apple' && (
      <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
        <path
          d="M17.05 20.28c-.98.95-2.05.8-3.08.35-1.09-.46-2.09-.48-3.24 0-1.44.62-2.2.44-3.06-.35C2.79 15.25 3.51 7.59 8.02 7.31c1.24.07 2.11.68 2.84.73.99-.13 1.94-.72 3.02-.65 1.28.09 2.24.61 2.87 1.53-2.64 1.62-2.02 5.1.32 6.03-.51 1.11-1.16 2.2-2.02 3.06zM12.03 7.25c-.13-2.19 1.64-3.98 3.62-4.25.28 2.31-2.15 4.14-3.62 4.25z"
        />
      </svg>
    )}
    {store === 'google' && (
      <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
        <path d="M4 3.2v17.6c0 .5.5.8.9.5l14.3-8.8c.4-.3.4-.9 0-1.1L4.9 2.7c-.4-.3-.9 0-.9.5z" />
      </svg>
    )}
  </span>
  <span class="flex flex-col leading-none">
    <span class="label text-[0.6rem] text-ash">{meta.small}</span>
    <span class="mt-1 text-sm font-medium text-bone">{meta.big}</span>
  </span>
</a>

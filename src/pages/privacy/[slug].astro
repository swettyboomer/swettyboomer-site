---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { SITE } from '../../consts';

export async function getStaticPaths() {
  const apps = await getCollection('apps');
  return apps.map((app) => ({ params: { slug: app.id }, props: { app } }));
}

const { app } = Astro.props;
const { data } = app;
const { dataCollected, thirdParties } = data.privacy;

const collectsData = dataCollected.length > 0;
const sharesData = thirdParties.length > 0;

// A hand-written, detailed policy for an app lives in src/policies/<slug>.md and
// takes precedence over the generic template below. Drop a file there to give an
// app its own full policy; otherwise the boilerplate is generated from the app's
// privacy.dataCollected / privacy.thirdParties fields.
const policyModules = import.meta.glob('../../policies/*.md', { eager: true });
const detailed = policyModules[`../../policies/${app.id}.md`] as
  | { Content: any; frontmatter: { lastUpdated?: string } }
  | undefined;
const DetailedContent = detailed?.Content;
---
<BaseLayout
  title={`${data.name} Privacy Policy`}
  description={`Privacy policy for ${data.name} by ${SITE.name}.`}
>
  <div class="mx-auto max-w-3xl px-5 py-16 sm:px-8 sm:py-24">
    <a
      href={`/apps/${app.id}`}
      class="label inline-flex items-center gap-1.5 text-ash transition-colors hover:text-bone"
    >
      ← {data.name}
    </a>

    <h1 class="mt-6 text-3xl font-semibold tracking-tight text-bone sm:text-4xl">
      {data.name} Privacy Policy
    </h1>
    <p class="label mt-3">
      {
        detailed?.frontmatter?.lastUpdated
          ? `Last updated ${detailed.frontmatter.lastUpdated}`
          : `Effective ${SITE.privacyEffective}`
      }
    </p>

    {
      DetailedContent ? (
        <div class="policy mt-10">
          <DetailedContent />
        </div>
      ) : (
        <div class="policy mt-10">
          <p>
            This policy explains what information {data.name} collects, how it is
            used, and the choices you have. {data.name} is published by {SITE.name}
            (&ldquo;we&rdquo;), an independent software publisher. If you have any
            questions, contact us at
            <a href={`mailto:${SITE.email}`}>{SITE.email}</a>.
          </p>

          <h2>Information we collect</h2>
          {collectsData ? (
            <>
              <p>{data.name} collects the following information:</p>
              <ul>
                {dataCollected.map((item) => (
                  <li>{item}</li>
                ))}
              </ul>
            </>
          ) : (
            <p>
              {data.name} does not collect personal information. Your data stays
              on your device and is never transmitted to us or to anyone else.
            </p>
          )}

          <h2>How we use information</h2>
          {collectsData ? (
            <p>
              We use the information above only to operate and improve {data.name}
              — to provide the app's features, respond to support requests you
              send us, diagnose crashes, and understand which features are used.
              We do not sell your personal information, and we do not use it for
              advertising.
            </p>
          ) : (
            <p>
              Because {data.name} does not collect personal information, there is
              nothing for us to use, sell, or share. The app functions entirely on
              your device.
            </p>
          )}

          <h2>Sharing and third parties</h2>
          {sharesData ? (
            <>
              <p>
                {data.name} relies on the following third-party services. Each
                receives only the information needed to perform its function, and
                each handles that information under its own privacy policy:
              </p>
              <ul>
                {thirdParties.map((item) => (
                  <li>{item}</li>
                ))}
              </ul>
              <p>
                We do not sell your personal information or share it with third
                parties for their own marketing.
              </p>
            </>
          ) : (
            <p>
              {data.name} does not share your information with any third parties.
            </p>
          )}

          <h2>Data retention</h2>
          <p>
            {collectsData
              ? `We keep information only as long as needed for the purposes described above. Support emails are retained so we can help with follow-up questions; you may ask us to delete them at any time. Any data stored on your device remains until you delete it or uninstall ${data.name}.`
              : `Any data ${data.name} creates is stored on your device and remains under your control. Deleting it, or uninstalling the app, removes it.`}
          </p>

          <h2>Your choices and rights</h2>
          <p>
            You may request access to, correction of, or deletion of any personal
            information we hold about you. To make a request, email
            <a href={`mailto:${SITE.email}`}>{SITE.email}</a> and we will respond
            within a reasonable time. Depending on where you live, you may have
            additional rights under laws such as the GDPR or CCPA; we honor those
            rights regardless of your location.
          </p>

          <h2>Children's privacy</h2>
          <p>
            {data.name} is not directed to children under 13, and we do not
            knowingly collect personal information from them. If you believe a child
            has provided us information, contact us and we will delete it.
          </p>

          <h2>Changes to this policy</h2>
          <p>
            We may update this policy from time to time. When we do, we will revise
            the effective date above and, where appropriate, note the change within
            the app. Continued use of {data.name} after an update means you accept
            the revised policy.
          </p>

          <h2>Contact</h2>
          <p>
            For any question about this policy or your data, email
            <a href={`mailto:${SITE.email}`}>{SITE.email}</a>.
          </p>
        </div>
      )
    }
  </div>
</BaseLayout>
